//@version=6
strategy("ATLAS // BACKTEST", overlay=true, pyramiding=0,
     default_qty_type=strategy.percent_of_equity, default_qty_value=2,
     initial_capital=10000, commission_value=0.02, slippage=1,
     calc_on_every_tick=false)

// ── INPUTS ──────────────────────────────────────────────────────────────────
emaLen   = input.int(200, "EMA Length")
rsiLen   = input.int(14, "RSI Length")
atrLen   = input.int(14, "ATR Length")
macdFast = input.int(12, "MACD Fast")
macdSlow = input.int(26, "MACD Slow")
macdSig  = input.int(9, "MACD Signal")
startDate = input.time(timestamp("2026-03-31"), "Start Date")

// ── OPTIMIZABLE INPUTS ─────────────────────────────────────────────────────
minRR             = input.float(1.5, "Min R:R Filter",          minval=1.0, maxval=3.0, step=0.5)
minBiasScore      = input.float(2.0, "Min Bias Score",          minval=1.0, maxval=5.0, step=0.5)
minWeightedStruct = input.float(1.0, "Min Weighted Structure",  minval=0.5, maxval=5.0, step=0.5)
rsiGateLong       = input.int(40,    "RSI Gate Long",           minval=30,  maxval=55,  step=5)
rsiGateShort      = input.int(75,    "RSI Gate Short",          minval=55,  maxval=80,  step=5)
atrEntryMult      = input.float(0.35,"ATR Entry Multiplier",    minval=0.1, maxval=0.8, step=0.1)
atrSlMult         = input.float(1.5, "ATR SL Multiplier",       minval=0.8, maxval=2.5, step=0.1)
atrTpMult         = input.float(3.0, "ATR TP Multiplier",       minval=1.5, maxval=5.0, step=0.5)

// ── INDICATORS — CURRENT TF ────────────────────────────────────────────────
ema200  = ta.ema(close, emaLen)
rsi14   = ta.rsi(close, rsiLen)
atr14   = ta.atr(atrLen)
vwapVal = ta.vwap(hlc3)
[macdLine, signalLine, macdHist] = ta.macd(close, macdFast, macdSlow, macdSig)

// ── MULTI-TIMEFRAME EMA200 ─────────────────────────────────────────────────
ema200_1d = request.security(syminfo.tickerid, "D", ta.ema(close, emaLen), lookahead=barmerge.lookahead_on)
ema200_4h = request.security(syminfo.tickerid, "240", ta.ema(close, emaLen), lookahead=barmerge.lookahead_on)
ema200_1h = request.security(syminfo.tickerid, "60",  ta.ema(close, emaLen), lookahead=barmerge.lookahead_on)

// ── MULTI-TIMEFRAME STRUCTURE ───────────────────────────────────────────────
// Bullish: close > prior 5-bar high | Bearish: close < prior 5-bar low
f_struct(_close, _high, _low) =>
    bull = _close > ta.highest(_high, 5)[1]
    bear = _close < ta.lowest(_low, 5)[1]
    bull ? 1 : bear ? -1 : 0

struct_1d  = request.security(syminfo.tickerid, "D",  f_struct(close, high, low), lookahead=barmerge.lookahead_on)
struct_4h  = request.security(syminfo.tickerid, "240", f_struct(close, high, low), lookahead=barmerge.lookahead_on)
struct_1h  = request.security(syminfo.tickerid, "60",  f_struct(close, high, low), lookahead=barmerge.lookahead_on)
struct_15m = request.security(syminfo.tickerid, "15",  f_struct(close, high, low), lookahead=barmerge.lookahead_on)

// ── BIAS SCORE (-8 to +8) ──────────────────────────────────────────────────
biasScore = (close > ema200_1d ? 3.0 : -3.0)
     + (close > ema200_4h ? 2.0 : -2.0)
     + (close > ema200_1h ? 1.5 : -1.5)
     + (rsi14 > 50 ? 1.0 : -1.0)
     + (rsi14 > 50 ? 1.0 : -1.0)
     + (macdHist > 0 ? 1.0 : -1.0)
     + (close > vwapVal ? 0.5 : -0.5)

// ── DIRECTION ───────────────────────────────────────────────────────────────
// Primary: bias score threshold. Fallback: 1d+1h structure agreement in dead zone.
inDeadZone = biasScore > -minBiasScore and biasScore < minBiasScore
isLong  = biasScore >= minBiasScore or (inDeadZone and struct_1d == 1 and struct_1h == 1)
isShort = biasScore <= -minBiasScore or (inDeadZone and struct_1d == -1 and struct_1h == -1)

// ── HARD GATES ──────────────────────────────────────────────────────────────
longBlocked  = rsi14 < rsiGateLong
longBlocked := longBlocked or (struct_1d == -1)
longBlocked := longBlocked or (struct_1h == -1 and struct_4h == -1)

shortBlocked  = rsi14 > rsiGateShort
shortBlocked := shortBlocked or (struct_1d == 1)
shortBlocked := shortBlocked or (struct_1h == 1 and struct_4h == 1)

// ── WEIGHTED STRUCTURE SCORE ────────────────────────────────────────────────
// Aligned = structure matches direction. Weight × 1 if aligned, 0 if not.
longStructScore  = (struct_1d  == 1 ? 3.0 : 0.0) + (struct_4h == 1 ? 2.0 : 0.0) + (struct_1h == 1 ? 1.5 : 0.0) + (struct_15m == 1 ? 1.0 : 0.0)
shortStructScore = (struct_1d  == -1 ? 3.0 : 0.0) + (struct_4h == -1 ? 2.0 : 0.0) + (struct_1h == -1 ? 1.5 : 0.0) + (struct_15m == -1 ? 1.0 : 0.0)
weightedStruct   = isLong ? longStructScore : isShort ? shortStructScore : 0.0

// Strong bias (abs >= 4) bypasses structure gate — bias overrides weak alignment
structGate = math.abs(biasScore) >= 4.0 or weightedStruct >= minWeightedStruct

// ── ENTRY / SL / TP ────────────────────────────────────────────────────────
longEntry  = close + atr14 * atrEntryMult
shortEntry = close - atr14 * atrEntryMult

longSL  = longEntry  - atr14 * atrSlMult
shortSL = shortEntry + atr14 * atrSlMult

longTP1  = longEntry  + math.abs(longEntry  - longSL)            // 1:1 RR
longTP2  = longEntry  + atr14 * atrTpMult                        // main target
longTP3  = longTP2    + math.abs(longEntry  - longSL) * 0.5      // stretch

shortTP1 = shortEntry - math.abs(shortEntry - shortSL)
shortTP2 = shortEntry - atr14 * atrTpMult
shortTP3 = shortTP2   - math.abs(shortEntry - shortSL) * 0.5

// ── RR GATE ─────────────────────────────────────────────────────────────────
longRR  = math.abs(longTP2  - longEntry)  / math.abs(longSL  - longEntry)
shortRR = math.abs(shortTP2 - shortEntry) / math.abs(shortSL - shortEntry)
rrPass  = isLong ? longRR >= minRR : isShort ? shortRR >= minRR : false

// ── FINAL SIGNAL ────────────────────────────────────────────────────────────
afterStart = time >= startDate
noPosition = strategy.position_size == 0

goLong  = afterStart and noPosition and isLong  and not longBlocked  and structGate and rrPass
goShort = afterStart and noPosition and isShort and not shortBlocked and structGate and rrPass

// ── STRATEGY EXECUTION ─────────────────────────────────────────────────────
if goLong
    strategy.entry("LONG", strategy.long)
    strategy.exit("LONG_EXIT", "LONG", stop=longSL, limit=longTP2)
    alert('{"symbol":"' + syminfo.ticker + '","direction":"LONG","entry":' + str.tostring(longEntry) + ',"sl":' + str.tostring(longSL) + ',"tp1":' + str.tostring(longTP1) + ',"tp2":' + str.tostring(longTP2) + ',"tp3":' + str.tostring(longTP3) + ',"rr":' + str.tostring(math.round(longRR * 100) / 100) + ',"biasScore":' + str.tostring(biasScore) + ',"weightedStruct":' + str.tostring(weightedStruct) + ',"time":"' + str.tostring(timenow) + '"}', alert.freq_once_per_bar)

if goShort
    strategy.entry("SHORT", strategy.short)
    strategy.exit("SHORT_EXIT", "SHORT", stop=shortSL, limit=shortTP2)
    alert('{"symbol":"' + syminfo.ticker + '","direction":"SHORT","entry":' + str.tostring(shortEntry) + ',"sl":' + str.tostring(shortSL) + ',"tp1":' + str.tostring(shortTP1) + ',"tp2":' + str.tostring(shortTP2) + ',"tp3":' + str.tostring(shortTP3) + ',"rr":' + str.tostring(math.round(shortRR * 100) / 100) + ',"biasScore":' + str.tostring(biasScore) + ',"weightedStruct":' + str.tostring(weightedStruct) + ',"time":"' + str.tostring(timenow) + '"}', alert.freq_once_per_bar)

// ── PLOTS — OVERLAY ─────────────────────────────────────────────────────────
inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0

plot(inLong ? longSL   : inShort ? shortSL   : na, "SL",  color=color.red,    style=plot.style_linebr, linewidth=1)
plot(inLong ? longTP1  : inShort ? shortTP1  : na, "TP1", color=color.yellow,  style=plot.style_linebr, linewidth=1)
plot(inLong ? longTP2  : inShort ? shortTP2  : na, "TP2", color=color.green,   style=plot.style_linebr, linewidth=2)
plot(inLong ? longTP3  : inShort ? shortTP3  : na, "TP3", color=color.teal,    style=plot.style_linebr, linewidth=1)

// Entry marker
plotshape(goLong,  "Long Signal",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(goShort, "Short Signal", shape.triangledown,  location.abovebar, color.red,   size=size.small)

// ── DEBUG LABEL — last bar diagnostic (remove after troubleshooting) ────────
if barstate.islast
    debugTxt = "=== ATLAS DEBUG ===\n"
     + "biasScore: " + str.tostring(biasScore, "#.#") + "\n"
     + "weightedStruct: " + str.tostring(weightedStruct, "#.#") + "\n"
     + "isLong: " + str.tostring(isLong) + "  isShort: " + str.tostring(isShort) + "\n"
     + "longBlocked: " + str.tostring(longBlocked) + "  shortBlocked: " + str.tostring(shortBlocked) + "\n"
     + "structGate: " + str.tostring(structGate) + "\n"
     + "rrPass: " + str.tostring(rrPass) + "\n"
     + "goLong: " + str.tostring(goLong) + "  goShort: " + str.tostring(goShort) + "\n"
     + "afterStart: " + str.tostring(afterStart) + "  noPos: " + str.tostring(noPosition) + "\n"
     + "--- COMPONENTS ---\n"
     + "ema200_1d: " + str.tostring(ema200_1d, "#.##") + (na(ema200_1d) ? " [NA!]" : "") + "\n"
     + "ema200_4h: " + str.tostring(ema200_4h, "#.##") + (na(ema200_4h) ? " [NA!]" : "") + "\n"
     + "ema200_1h: " + str.tostring(ema200_1h, "#.##") + (na(ema200_1h) ? " [NA!]" : "") + "\n"
     + "rsi14: " + str.tostring(rsi14, "#.#") + "\n"
     + "macdHist: " + str.tostring(macdHist, "#.####") + "\n"
     + "vwap: " + str.tostring(vwapVal, "#.##") + (na(vwapVal) ? " [NA!]" : "") + "\n"
     + "atr14: " + str.tostring(atr14, "#.##") + (na(atr14) ? " [NA!]" : "") + "\n"
     + "--- STRUCTURE ---\n"
     + "1d:" + str.tostring(struct_1d) + (na(struct_1d) ? "[NA!]" : "")
     + "  4h:" + str.tostring(struct_4h) + (na(struct_4h) ? "[NA!]" : "")
     + "  1h:" + str.tostring(struct_1h) + (na(struct_1h) ? "[NA!]" : "")
     + "  15m:" + str.tostring(struct_15m) + (na(struct_15m) ? "[NA!]" : "") + "\n"
     + "--- LEVELS ---\n"
     + "longRR: " + str.tostring(longRR, "#.##") + "  shortRR: " + str.tostring(shortRR, "#.##") + "\n"
     + "close: " + str.tostring(close) + "  entry_L: " + str.tostring(longEntry, "#.##") + "  sl_L: " + str.tostring(longSL, "#.##")
    label.new(bar_index, high, debugTxt, style=label.style_label_down, color=color.new(color.black, 20), textcolor=color.white, size=size.normal)

// ── PLOTS — SEPARATE PANES ─────────────────────────────────────────────────
plot(biasScore,     "Bias Score",      color=biasScore > 0 ? color.green : color.red, display=display.pane)
hline(2,  "Long Threshold",  color=color.gray, linestyle=hline.style_dotted, display=display.all)
hline(-2, "Short Threshold", color=color.gray, linestyle=hline.style_dotted, display=display.all)
hline(0,  "Zero",            color=color.gray, linestyle=hline.style_dashed, display=display.all)

plot(weightedStruct, "Weighted Structure", color=color.orange, display=display.pane)
hline(1,  "Min Struct Gate",  color=color.gray, linestyle=hline.style_dotted, display=display.all)
