//@version=6
strategy("ATLAS // COMBINED", overlay=true, pyramiding=0,
         default_qty_type=strategy.percent_of_equity, default_qty_value=2,
         initial_capital=10000, commission_value=0.02, slippage=1,
         calc_on_every_tick=false)

// ── INPUTS ──────────────────────────────────────────────────────────────────
swingLen     = input.int(10,    "Swing Lookback",               minval=5,    maxval=20,   step=5)
obLookback   = input.int(5,     "Order Block Lookback",  minval=3,   maxval=10,  step=1)
rsiLen       = input.int(14,    "RSI Length")
atrLen       = input.int(14,    "ATR Length")
volLen       = input.int(20,    "Volume MA Length")
minRR        = input.float(3.0, "Min R:R",               minval=2.0, maxval=5.0, step=0.5)
useCloud     = input.bool(true, "Ichimoku Cloud Filter")
useVolume    = input.bool(true, "Volume Confirmation")
useRsiDiv    = input.bool(true, "RSI Divergence Filter")
startDate    = input.time(timestamp("2026-03-31"), "Start Date")

// ── LAYER 1 — ICHIMOKU CLOUD ────────────────────────────────────────────────
tenkan   = (ta.highest(high, 9)  + ta.lowest(low, 9))  / 2
kijun    = (ta.highest(high, 26) + ta.lowest(low, 26)) / 2
spanA    = (tenkan + kijun) / 2
spanB    = (ta.highest(high, 52) + ta.lowest(low, 52)) / 2
cloudTop    = math.max(spanA, spanB)
cloudBot    = math.min(spanA, spanB)
aboveCloud  = close > cloudTop
belowCloud  = close < cloudBot

// ── LAYER 2 — DAILY BIAS (via request.security, no heavy lookback) ──────────
dailyClose = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_off)
dailyOpen  = request.security(syminfo.tickerid, "D", open[1],  lookahead=barmerge.lookahead_off)
dailyHigh  = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_off)
dailyLow   = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_off)
dailyMid   = (dailyHigh + dailyLow) / 2
dailyBull  = close > dailyMid
dailyBear  = close < dailyMid

// ── LAYER 3 — BREAK OF STRUCTURE ────────────────────────────────────────────
swingHigh = ta.pivothigh(high, swingLen, swingLen)
swingLow  = ta.pivotlow(low,   swingLen, swingLen)

var float lastSwingHigh = na
var float lastSwingLow  = na
if not na(swingHigh)
    lastSwingHigh := swingHigh
if not na(swingLow)
    lastSwingLow := swingLow

bullBOS = not na(lastSwingHigh) and close > lastSwingHigh and close[1] <= lastSwingHigh
bearBOS = not na(lastSwingLow)  and close < lastSwingLow  and close[1] >= lastSwingLow

var int bosDir = 0
if bullBOS
    bosDir := 1
if bearBOS
    bosDir := -1

// ── LAYER 4 — ORDER BLOCK ──────────────────────────────────────────────────
var float obBullTop = na
var float obBullBot = na
var float obBearTop = na
var float obBearBot = na

if bullBOS
    for i = 1 to obLookback
        if close[i] < open[i]
            obBullTop := high[i]
            obBullBot := low[i]
            break

if bearBOS
    for i = 1 to obLookback
        if close[i] > open[i]
            obBearTop := high[i]
            obBearBot := low[i]
            break

// ── LAYER 5 — 4H PULLBACK (via request.security) ───────────────────────────
atr14   = ta.atr(atrLen)
htfHigh = request.security(syminfo.tickerid, "240", high[1], lookahead=barmerge.lookahead_off)
htfLow  = request.security(syminfo.tickerid, "240", low[1],  lookahead=barmerge.lookahead_off)

pulledBackBull = close < htfHigh - atr14 * 0.3
pulledBackBear = close > htfLow  + atr14 * 0.3

inObBull = not na(obBullTop) and close <= obBullTop and close >= obBullBot
inObBear = not na(obBearTop) and close >= obBearBot and close <= obBearTop

// ── LAYER 6 — REJECTION CANDLE ──────────────────────────────────────────────
candleRange = high - low
lowerWick   = math.min(open, close) - low
upperWick   = high - math.max(open, close)
bullRej = candleRange > 0 and lowerWick > candleRange * 0.35 and close > (low + candleRange * 0.45)
bearRej = candleRange > 0 and upperWick > candleRange * 0.35 and close < (high - candleRange * 0.45)

// ── LAYER 7 — RSI DIVERGENCE ────────────────────────────────────────────────
rsi14 = ta.rsi(close, rsiLen)

rsiDivBull = false
rsiDivBear = false
if useRsiDiv
    priceLow1  = ta.lowest(low,     5)
    priceLow2  = ta.lowest(low[5],  5)
    rsiLow1    = ta.lowest(rsi14,   5)
    rsiLow2    = ta.lowest(rsi14[5],5)
    priceHigh1 = ta.highest(high,     5)
    priceHigh2 = ta.highest(high[5],  5)
    rsiHigh1   = ta.highest(rsi14,    5)
    rsiHigh2   = ta.highest(rsi14[5], 5)
    rsiDivBull := priceLow1  < priceLow2  and rsiLow1  > rsiLow2
    rsiDivBear := priceHigh1 > priceHigh2 and rsiHigh1 < rsiHigh2

// ── LAYER 8 — VOLUME CONFIRMATION ──────────────────────────────────────────
volMA   = ta.sma(volume, volLen)
highVol = useVolume ? volume > volMA * 1.3 : true

// ── LAYER 9 — THREE-CLASS ENTRY SYSTEM ──────────────────────────────────────
// TIER 1: Hard requirements (mandatory)
tier1Long  = dailyBull and bosDir == 1 and bullRej
tier1Short = dailyBear and bosDir == -1 and bearRej

// TIER 2: Strong filters (count 0-3)
tier2Long  = (aboveCloud ? 1 : 0) + (inObBull ? 1 : 0) + (pulledBackBull ? 1 : 0)
tier2Short = (belowCloud ? 1 : 0) + (inObBear ? 1 : 0) + (pulledBackBear ? 1 : 0)

// BONUS: Confirmation (count 0-2)
bonusLong  = (rsiDivBull ? 1 : 0) + (highVol ? 1 : 0)
bonusShort = (rsiDivBear ? 1 : 0) + (highVol ? 1 : 0)

// Class assignment
classA_Long  = tier1Long  and tier2Long  == 3 and bonusLong  >= 1
classB_Long  = tier1Long  and tier2Long  >= 2 and not classA_Long
classC_Long  = tier1Long  and tier2Long  == 1

classA_Short = tier1Short and tier2Short == 3 and bonusShort >= 1
classB_Short = tier1Short and tier2Short >= 2 and not classA_Short
classC_Short = tier1Short and tier2Short == 1

// Score
scoreLong  = classA_Long  ? 88 : classB_Long  ? 75 : classC_Long  ? 62 : 0
scoreShort = classA_Short ? 88 : classB_Short ? 75 : classC_Short ? 62 : 0

// ── LAYER 10 — SL AND TP ───────────────────────────────────────────────────
// Class A: SL at OB (tightest). Class B: SL at swing. Class C: SL at ATR.
slLong = classA_Long ?
     (not na(obBullBot) ? obBullBot - atr14 * 0.1 : close - atr14 * 1.0) :
     classB_Long ?
     (not na(lastSwingLow) ? lastSwingLow - atr14 * 0.1 : close - atr14 * 1.2) :
     close - atr14 * 1.5

slShort = classA_Short ?
     (not na(obBearTop) ? obBearTop + atr14 * 0.1 : close + atr14 * 1.0) :
     classB_Short ?
     (not na(lastSwingHigh) ? lastSwingHigh + atr14 * 0.1 : close + atr14 * 1.2) :
     close + atr14 * 1.5

slLong  := math.min(slLong,  close - atr14 * 0.5)
slShort := math.max(slShort, close + atr14 * 0.5)

slDistL = close - slLong
slDistS = slShort - close
tpLong  = close + slDistL * minRR
tpShort = close - slDistS * minRR

// All classes enter
goLong  = (classA_Long  or classB_Long  or classC_Long)  and strategy.position_size == 0 and time >= startDate
goShort = (classA_Short or classB_Short or classC_Short) and strategy.position_size == 0 and time >= startDate

// ── STRATEGY EXECUTION ─────────────────────────────────────────────────────
if goLong
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=slLong, limit=tpLong)
    alert('{"symbol":"' + syminfo.ticker + '","direction":"LONG","class":"' + (classA_Long ? "A" : classB_Long ? "B" : "C") + '","entry":' + str.tostring(close) + ',"sl":' + str.tostring(slLong) + ',"tp":' + str.tostring(tpLong) + ',"rr":' + str.tostring(minRR) + ',"score":' + str.tostring(scoreLong) + ',"time":"' + str.format_time(time, "yyyy-MM-dd'T'HH:mm:ss") + '"}', alert.freq_once_per_bar)

if goShort
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=slShort, limit=tpShort)
    alert('{"symbol":"' + syminfo.ticker + '","direction":"SHORT","class":"' + (classA_Short ? "A" : classB_Short ? "B" : "C") + '","entry":' + str.tostring(close) + ',"sl":' + str.tostring(slShort) + ',"tp":' + str.tostring(tpShort) + ',"rr":' + str.tostring(minRR) + ',"score":' + str.tostring(scoreShort) + ',"time":"' + str.format_time(time, "yyyy-MM-dd'T'HH:mm:ss") + '"}', alert.freq_once_per_bar)

// ── PLOTS ───────────────────────────────────────────────────────────────────
// Cloud
p1 = plot(useCloud ? spanA : na, "Span A", color.new(color.green, 80))
p2 = plot(useCloud ? spanB : na, "Span B", color.new(color.red,   80))
fill(p1, p2, color=spanA > spanB ? color.new(color.green, 90) : color.new(color.red, 90))

// Daily range
plot(dailyHigh, "Daily High", color.new(color.red,   60), 1)
plot(dailyLow,  "Daily Low",  color.new(color.green, 60), 1)
plot(dailyMid,  "Daily Mid",  color.new(color.gray,  70), 1, plot.style_circles)

// BOS markers
plotshape(bullBOS, "Bull BOS", shape.labelup,   location.belowbar, color.green, text="BOS", size=size.small)
plotshape(bearBOS, "Bear BOS", shape.labeldown,  location.abovebar, color.red,   text="BOS", size=size.small)

// Order blocks
var box obBullBox = na
var box obBearBox = na
if bullBOS and not na(obBullTop)
    obBullBox := box.new(bar_index - obLookback, obBullTop, bar_index + 30, obBullBot,
                         border_color=color.green, bgcolor=color.new(color.green, 85))
if bearBOS and not na(obBearTop)
    obBearBox := box.new(bar_index - obLookback, obBearTop, bar_index + 30, obBearBot,
                         border_color=color.red, bgcolor=color.new(color.red, 85))

// Class A — large triangles
plotshape(goLong  and classA_Long,  "A Long",  shape.triangleup,   location.belowbar, color.green,               size=size.large)
plotshape(goShort and classA_Short, "A Short", shape.triangledown,  location.abovebar, color.red,                 size=size.large)
// Class B — normal triangles
plotshape(goLong  and classB_Long,  "B Long",  shape.triangleup,   location.belowbar, color.new(color.green, 30), size=size.normal)
plotshape(goShort and classB_Short, "B Short", shape.triangledown,  location.abovebar, color.new(color.red,   30), size=size.normal)
// Class C — small triangles
plotshape(goLong  and classC_Long,  "C Long",  shape.triangleup,   location.belowbar, color.new(color.green, 50), size=size.small)
plotshape(goShort and classC_Short, "C Short", shape.triangledown,  location.abovebar, color.new(color.red,   50), size=size.small)

// Class labels
if goLong
    label.new(bar_index, low - atr14,
              classA_Long ? "A" : classB_Long ? "B" : "C",
              color=classA_Long ? color.green : classB_Long ? color.new(color.green, 30) : color.new(color.green, 50),
              textcolor=color.white, size=size.small, style=label.style_label_up)
if goShort
    label.new(bar_index, high + atr14,
              classA_Short ? "A" : classB_Short ? "B" : "C",
              color=classA_Short ? color.red : classB_Short ? color.new(color.red, 30) : color.new(color.red, 50),
              textcolor=color.white, size=size.small, style=label.style_label_down)

// Rejection dots
plotshape(bullRej and bosDir == 1,  "Bull Rej", shape.circle, location.belowbar, color.new(color.green, 50), size=size.tiny)
plotshape(bearRej and bosDir == -1, "Bear Rej", shape.circle, location.abovebar, color.new(color.red,   50), size=size.tiny)

// ── DEBUG TABLE ─────────────────────────────────────────────────────────────
classLong  = classA_Long ? "A" : classB_Long ? "B" : classC_Long ? "C" : "NONE"
classShort = classA_Short ? "A" : classB_Short ? "B" : classC_Short ? "C" : "NONE"
classStr   = classLong != "NONE" ? classLong : classShort != "NONE" ? classShort : "NONE"
classClr   = classStr == "A" ? color.green : classStr == "B" ? color.yellow : classStr == "C" ? color.blue : color.gray

var table dbg = table.new(position.top_right, 2, 10,
                           bgcolor=color.new(color.black, 70), border_width=1)
table.cell(dbg, 0, 0, "Tier1",     text_color=color.white, text_size=size.small)
table.cell(dbg, 1, 0, tier1Long ? "LONG" : tier1Short ? "SHORT" : "no",
           text_color=tier1Long ? color.green : tier1Short ? color.red : color.gray, text_size=size.small)
table.cell(dbg, 0, 1, "Tier2",     text_color=color.white, text_size=size.small)
table.cell(dbg, 1, 1, str.tostring(tier1Long ? tier2Long : tier2Short) + "/3",
           text_color=(tier1Long ? tier2Long : tier2Short) == 3 ? color.green : (tier1Long ? tier2Long : tier2Short) >= 2 ? color.yellow : color.gray, text_size=size.small)
table.cell(dbg, 0, 2, "Bonus",     text_color=color.white, text_size=size.small)
table.cell(dbg, 1, 2, str.tostring(tier1Long ? bonusLong : bonusShort) + "/2",
           text_color=(tier1Long ? bonusLong : bonusShort) >= 1 ? color.green : color.gray, text_size=size.small)
table.cell(dbg, 0, 3, "Class",     text_color=color.white, text_size=size.small)
table.cell(dbg, 1, 3, classStr,    text_color=classClr,    text_size=size.small)
table.cell(dbg, 0, 4, "Score",     text_color=color.white, text_size=size.small)
table.cell(dbg, 1, 4, str.tostring(math.max(scoreLong, scoreShort)),
           text_color=classClr, text_size=size.small)
table.cell(dbg, 0, 5, "BOS Dir",   text_color=color.white, text_size=size.small)
table.cell(dbg, 1, 5, bosDir == 1 ? "BULL" : bosDir == -1 ? "BEAR" : "NONE",
           text_color=bosDir == 1 ? color.green : bosDir == -1 ? color.red : color.gray, text_size=size.small)
table.cell(dbg, 0, 6, "Cloud",     text_color=color.white, text_size=size.small)
table.cell(dbg, 1, 6, aboveCloud ? "ABOVE" : belowCloud ? "BELOW" : "INSIDE",
           text_color=aboveCloud ? color.green : belowCloud ? color.red : color.yellow, text_size=size.small)
table.cell(dbg, 0, 7, "RSI Div",   text_color=color.white, text_size=size.small)
table.cell(dbg, 1, 7, rsiDivBull ? "BULL" : rsiDivBear ? "BEAR" : "none",
           text_color=rsiDivBull ? color.green : rsiDivBear ? color.red : color.gray, text_size=size.small)
table.cell(dbg, 0, 8, "goLong",    text_color=color.white, text_size=size.small)
table.cell(dbg, 1, 8, goLong ? "FIRE" : "-",
           text_color=goLong ? color.green : color.gray, text_size=size.small)
table.cell(dbg, 0, 9, "goShort",   text_color=color.white, text_size=size.small)
table.cell(dbg, 1, 9, goShort ? "FIRE" : "-",
           text_color=goShort ? color.red : color.gray, text_size=size.small)

// ── ALERTS ──────────────────────────────────────────────────────────────────
alertcondition(goLong  and classA_Long,  "Class A Long",  "CLASS A LONG signal")
alertcondition(goLong  and classB_Long,  "Class B Long",  "CLASS B LONG signal")
alertcondition(goLong  and classC_Long,  "Class C Long",  "CLASS C LONG signal")
alertcondition(goShort and classA_Short, "Class A Short", "CLASS A SHORT signal")
alertcondition(goShort and classB_Short, "Class B Short", "CLASS B SHORT signal")
alertcondition(goShort and classC_Short, "Class C Short", "CLASS C SHORT signal")
